{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping node_exporter (incl. textfile collector) and pihole6_exporter",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Homelab Observability",
  "uid": "homelab-observability",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["homelab", "node_exporter", "pihole", "speedtest"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Router Temperature (°C)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 75 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "router_temperature_celsius",
          "legendFormat": "router"
        }
      ]
    },
    {
      "id": 2,
      "title": "Router CPU per core (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "router_cpu_usage_percent",
          "legendFormat": "{{core}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Router Memory (bytes)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "router_memory_total_bytes",
          "legendFormat": "total"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "router_memory_available_bytes",
          "legendFormat": "available"
        }
      ]
    },
    {
      "id": 4,
      "title": "Internet Speed (Mb/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "speedtest_download_mbps",
          "legendFormat": "download"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "speedtest_upload_mbps",
          "legendFormat": "upload"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pi-hole: Queries vs Blocked",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "pihole_dns_queries_total",
          "legendFormat": "total queries"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "pihole_dns_queries_blocked_total",
          "legendFormat": "blocked"
        }
      ]
    },
    {
      "id": 6,
      "title": "Pi-hole: Queries by Type",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "pihole_query_by_type",
          "legendFormat": "{{type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Exporter Up (staleness check)",
      "type": "stat",
      "description": "If any of these go to 0, that exporter's metrics may be stale -- this is the alert this homelab was missing before the Pi-hole v6 incident (see docs/postmortems).",
      "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "name_and_value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "up{job=\"pihole6\"}",
          "legendFormat": "pihole6_exporter"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "dfnhxbhcjm3uoc" },
          "expr": "up{job=\"node\"}",
          "legendFormat": "node_exporter"
        }
      ]
    }
  ]
}
