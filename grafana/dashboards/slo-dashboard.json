{
  "dashboard": {
    "id": null,
    "uid": "slo-error-budget",
    "title": "SLO Error Budgets",
    "tags": [
      "slo",
      "reliability",
      "homelab"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "1m",
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {}
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "row",
        "title": "CronJob SLOs (99.9% success rate, 7d window)",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "collapsed": false
      },
      {
        "id": 2,
        "type": "stat",
        "title": "iptv-auto-switch",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 1
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "slo:cronjob:success_ratio_7d{owner_name=\"iptv-auto-switch\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 0.999
                }
              ]
            },
            "decimals": 4,
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "auto"
        }
      },
